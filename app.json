{
  "expo": {
    "name": "BayadTracker",
    "slug": "BayadTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/BayadTrackerLogo.png",
    "scheme": "bayadtracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/BayadTrackerLogo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nahiwagaan.BayadTracker"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/BayadTrackerLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/BayadTrackerLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c79acf4a-e89b-404a-84e4-712fb0f2a4ef"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c79acf4a-e89b-404a-84e4-712fb0f2a4ef"
    }
  }
}
